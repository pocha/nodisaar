rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /Users/{docId} {
      allow read: true;
      allow write: if request.auth != null;
    }
    match /Users/{docId}/WatchItems/{itemId} {
      allow read: true;
      allow write: if request.auth != null;
    }
    match /WatchItems/{itemId} {
      allow read: true;
      allow write: if false; // trigger only
    }
  }
}