{
  "manifest_version": 3,
  "name": "Nodisaar",
  "version": "1.0.0",
  "description": "Curate & share your OTT favourites with friends",
  "permissions": ["storage", "tabs", "scripting", "activeTab"],
  "host_permissions": [
    "https://www.netflix.com/*",
    "https://www.primevideo.com/*"
  ],
  "externally_connectable": {
    "matches": ["https://nodi-saar.github.io/*"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "favicon/favicon-16x16.png",
      "32": "favicon/favicon-32x32.png",
      "192": "favicon/android-chrome-192x192.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/settings/viewed/*"],
      "js": ["netflix-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.primevideo.com/region/in/settings/watch-history/*",
        "https://www.primevideo.com/settings/watch-history/*"
      ],
      "js": ["prime-content.js"],
      "run_at": "document_idle"
    }
  ]
}